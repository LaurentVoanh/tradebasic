```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
venv/
.venv/
node_modules/
vendor/
composer.lock

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Distribution / packaging
dist/
build/
*.egg-info/
.installed.cfg
*.egg

# Testing
.pytest_cache/
.mypy_cache/
.tox/

# Git
.git/
!.gitignore

# Backup files
*~
*.bak
*.orig
*.rej

# Compression
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Images (if accidentally added)
*.png
*.jpg
*.jpeg
*.bmp
*.gif
*.webm
```